VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
RESEND_API_KEY=your-resend-api-key
VITE_PADDLE_CLIENT_TOKEN=your-paddle-client-side-token
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
# Optional: override admin notify recipients for send-upgrade-email (else emails all role=admin)
# ADMIN_NOTIFY_EMAIL=support@reachdeskcrm.com

# Google Calendar Integration
# Get from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# VITE_ prefix makes the Client ID available in the browser (needed for OAuth redirect URL only)
# The Client Secret is NEVER exposed to the browser — used only in Supabase Edge Functions
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# PostHog Analytics & Session Replay (App mode only)
VITE_POSTHOG_KEY=phc_your_posthog_project_api_key
VITE_POSTHOG_HOST=https://us.i.posthog.com
